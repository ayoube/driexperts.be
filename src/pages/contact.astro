---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout current="contact" title="Contact">
<h1>Contactez-nous</h1>
<p>Besoin d'un dépannage urgent ? Une question ? Appelez-nous ou remplissez le formulaire.</p>
<p style="font-size:1.2rem;font-weight:700">📞 <a href="tel:+324****2323">0470 31 23 23</a> — <a href="tel:+322****5135">02 888 51 35</a></p>

<form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field">
  <input type="hidden" name="form-name" value="contact" />
  <p style="display:none"><label>Ne pas remplir: <input name="bot-field" /></label></p>
  <label for="name">Nom</label><input type="text" id="name" name="name" required />
  <label for="phone">Téléphone</label><input type="tel" id="phone" name="phone" required />
  <label for="email">Email</label><input type="email" id="email" name="email" />
  <label for="service">Service souhaité</label>
  <select id="service" name="service">
    <option value="">— Choisissez —</option>
    <option value="plomberie">Plomberie</option><option value="chauffage">Chauffage / Chaudière</option>
    <option value="debouchage">Débouchage</option><option value="electricite">Électricité</option>
    <option value="hvac">HVAC</option><option value="nettoyage">Nettoyage</option>
    <option value="autre">Autre</option>
  </select>
  <label for="message">Message</label><textarea id="message" name="message" rows="5" placeholder="Décrivez votre problème..."></textarea>
  <button type="submit">Envoyer</button>
</form>
</BaseLayout>
