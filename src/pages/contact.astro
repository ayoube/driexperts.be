---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout lang="fr" current="contact" title="Contactez-nous" description="Contactez DRI Expert pour un dépannage urgent ou un devis gratuit. Intervention rapide 7j/7 à Bruxelles.">
  <section class="section">
    <div class="container">
      <div class="page-content">
        <div class="breadcrumb"><a href="/">Accueil</a><span>/</span>Contact</div>
        <h1>Contactez-nous</h1>
        <p style="font-size:1.15rem;margin-bottom:2rem">
          Besoin d'un dépannage urgent ?<br>
          <strong style="font-size:1.3rem">📞 <a href="tel:+324****2323" style="color:var(--primary)">0470 31 23 23</a></strong> — <a href="tel:+322****5135">02 888 51 35</a>
        </p>

        <form name="contact-fr" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="contact-form">
          <input type="hidden" name="form-name" value="contact-fr" />
          <p style="display:none"><label>Ne pas remplir: <input name="bot-field" /></label></p>

          <div class="form-group">
            <label for="name">Nom complet *</label>
            <input type="text" id="name" name="name" required placeholder="Votre nom" />
          </div>
          <div class="form-group">
            <label for="phone">Téléphone *</label>
            <input type="tel" id="phone" name="phone" required placeholder="0470 00 00 00" />
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="vous@email.be" />
          </div>
          <div class="form-group">
            <label for="service">Service souhaité</label>
            <select id="service" name="service">
              <option value="">— Choisissez un service —</option>
              <option>Plomberie</option>
              <option>Chauffage / Chaudière</option>
              <option>Débouchage</option>
              <option>Électricité</option>
              <option>HVAC / Climatisation</option>
              <option>Nettoyage / Parachèvement</option>
              <option>Autre</option>
            </select>
          </div>
          <div class="form-group">
            <label for="message">Votre message</label>
            <textarea id="message" name="message" rows="5" placeholder="Décrivez votre problème ou demande..."></textarea>
          </div>
          <button type="submit" class="btn-submit">Envoyer la demande →</button>
        </form>

        <div style="margin-top:3rem;padding:2rem;background:var(--gray-50);border-radius:var(--radius-lg)">
          <h3 style="margin-bottom:0.5rem">📞 Urgence ? Appelez-nous directement</h3>
          <p style="font-size:1.2rem;font-weight:700;color:var(--primary)">
            <a href="tel:+324****2323" style="color:var(--primary)">0470 31 23 23</a> · <a href="tel:+322****5135">02 888 51 35</a>
          </p>
          <p style="color:var(--gray-600)">Disponible 7j/7 — Intervention en moins d'1h sur Bruxelles</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
