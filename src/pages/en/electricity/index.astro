          </div>
          <div class="card">
            <h3><a href="/en/electricity/installation/">Electrical Installation</a></h3>
            <p>Panel installation, lighting, outlets.</p>
            <a href="/en/electricity/installation/" style="color:var(--primary);font-weight:600;font-size:0.9rem">→ Request a free quote</a>
          </div>
          <div class="card">
            <h3><a href="/en/electricity/repair/">Electrical Repair</a></h3>
            <p>Electrical repair and compliance.</p>
            <a href="/en/electricity/repair/" style="color:var(--primary);font-weight:600;font-size:0.9rem">→ Request a free quote</a>
          </div>
      </div>
    </div>
  </section>
  <section class="section" style="text-align:center">
    <div class="container">
      <a href="/en/contact" class="btn btn-accent" style="font-size:1.1rem;padding:1rem 2.5rem">Request a free quote →</a>
    </div>
  </section>
