---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout lang="fr" current="contact" title="Contactez-nous">
<h1>Contactez-nous</h1>
<p>Besoin d'un dépannage ? 📞 <a href="tel:+324****2323">0470 31 23 23</a> — <a href="tel:+322****5135">02 888 51 35</a></p>
<form name="contact-fr" method="POST" data-netlify="true" netlify-honeypot="bot-field">
<input type="hidden" name="form-name" value="contact-fr" />
<p style="display:none"><label>Ne pas remplir: <input name="bot-field" /></label></p>
<label for="name">Nom</label><input type="text" id="name" name="name" required />
<label for="phone">Téléphone</label><input type="tel" id="phone" name="phone" required />
<label for="email">Email</label><input type="email" id="email" name="email" />
<label for="service">Service</label>
<select id="service" name="service"><option value="">— Choisissez —</option><option>Plomberie</option><option>Chauffage</option><option>Débouchage</option><option>Électricité</option><option>HVAC</option><option>Nettoyage</option><option>Autre</option></select>
<label for="message">Message</label><textarea id="message" name="message" rows="5"></textarea>
<button type="submit">Envoyer</button></form>
</BaseLayout>
