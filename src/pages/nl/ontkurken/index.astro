---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---
<BaseLayout lang="nl" current="debouchage" title="Ontkurken" description="Uw gezondheid zijn verstopt ? Niet uw gootsteen riool water ? Omdat we weten allemaal de schade die verstopte pijp in uw huis en eventuele overlast voor uw dage">
  <section class="section">
    <div class="container">
      <div class="page-content">
        <div class="breadcrumb"><a href="/nl/">Home</a> <span>/</span> <a href="/nl/ontkurken/">Ontkurken</a></div>
        <div style="margin: -2rem -2rem 2rem -2rem; height: 220px; background: url('/images/debouchage.jpg') center/cover no-repeat; border-radius: 0 0 var(--radius-lg) var(--radius-lg);"></div>
        <h1>Ontkurken</h1>
        <p>Uw gezondheid zijn verstopt ? Niet uw gootsteen riool water ? Omdat we weten allemaal de schade die verstopte pijp in uw huis en eventuele overlast voor uw dagelijks leven kunnen leiden , reageren we snel en professioneel . Dus maak jezelf en neem contact met ons zonder vertraging!</p>

<p><a href="/nl/contact">Neem contact met ons</a> zonder meer , bieden wij een passende oplossing met snelle levering en onklopbare prijzen!</p>

      </div>
    </div>
  </section>
  <section class="section section-gray">
    <div class="container">
      <div class="section-title">
        <h2>Nos services</h2>
      </div>
      <div class="grid-3">
          <div class="card">
            <h3><a href="/nl/ontkurken/problemen-oplossen/">Problemen Oplossen</a></h3>
            <p>Ontstopping. Camera-inspectie.</p>
            <a href="/nl/ontkurken/problemen-oplossen/" style="color:var(--primary);font-weight:600;font-size:0.9rem">→ Vraag een gratis offerte aan</a>
          </div>
      </div>
    </div>
  </section>
  <section class="section" style="text-align:center">
    <div class="container">
      <a href="/nl/contact" class="btn btn-accent" style="font-size:1.1rem;padding:1rem 2.5rem">Vraag een gratis offerte aan →</a>
    </div>
  </section>
</BaseLayout>
